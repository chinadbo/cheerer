{
  "name": "cheerer",
  "version": "1.0.0",
  "description": "Claude Code 鼓励师 — 任务完成时播放像素动画 + 语音鼓励",
  "author": "chinadbo",
  "repository": {
    "type": "git",
    "url": "https://github.com/chinadbo/cheerer.git"
  },
  "homepage": "https://github.com/chinadbo/cheerer",
  "bugs": {
    "url": "https://github.com/chinadbo/cheerer/issues"
  },
  "files": [
    "bin/",
    "scripts/",
    "hooks/",
    ".claude-plugin/",
    "README*.md",
    "CONTRIBUTING.md"
  ],
  "hooks": "./hooks/hooks.json",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "animation",
    "tts",
    "encouragement"
  ],
  "scripts": {
    "test": "bash scripts/cheer.sh",
    "test:basketball": "CHEERER_ANIM=basketball bash scripts/cheer.sh",
    "test:dance": "CHEERER_ANIM=dance bash scripts/cheer.sh",
    "test:fireworks": "CHEERER_ANIM=fireworks bash scripts/cheer.sh",
    "test:en": "CHEERER_LANG=en bash scripts/cheer.sh",
    "install": "chmod +x bin/cheer scripts/cheer.sh scripts/animations/*.sh scripts/voices/*.sh && echo '✅ 权限设置完成'"
  }
}
