{
  "name": "cheerer",
  "version": "2.0.0",
  "description": "Claude Code 鼓励师 — 任务完成时播放像素动画 + 语音鼓励",
  "author": "chinadbo",
  "repository": {
    "type": "git",
    "url": "https://github.com/chinadbo/cheerer.git"
  },
  "homepage": "https://github.com/chinadbo/cheerer",
  "bugs": {
    "url": "https://github.com/chinadbo/cheerer/issues"
  },
  "files": [
    "bin/",
    "scripts/",
    "hooks/",
    ".claude-plugin/",
    "README*.md",
    "CONTRIBUTING.md"
  ],
  "hooks": "./hooks/hooks.json",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "animation",
    "tts",
    "encouragement"
  ],
  "scripts": {
    "test": "bash tests/run.sh all",
    "test:state": "bash tests/run.sh state",
    "test:policy": "bash tests/run.sh policy",
    "test:render": "bash tests/run.sh render",
    "test:integration": "bash tests/run.sh integration",
    "install": "chmod +x bin/cheer scripts/cheer.sh scripts/animations/*.sh scripts/voices/*.sh tests/run.sh && echo '✅ permissions set'"
  }
}
